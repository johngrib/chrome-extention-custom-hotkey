{
  "manifest_version": 3,
  "name": "Custom Hotkey Clicker",
  "version": "1.5.0",
  "description": "Allows custom hotkeys for clicking elements on specific web pages.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
